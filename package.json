    "@formatjs/intl-pluralrules": "^5.4.6",
    "@lingui/core": "^5.9.5",
    "@lingui/react": "^5.9.5",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/app": "^23.8.8",
