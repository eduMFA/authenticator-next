    "@lingui/macro": "^5.9.5",
    "@lingui/metro-transformer": "^5.9.5",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.15",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
