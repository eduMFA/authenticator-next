    "expo-linking": "~56.0.11",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.12",
    "expo-router": "~56.2.5",
    "expo-splash-screen": "~56.0.9",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "jest": "~29.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
