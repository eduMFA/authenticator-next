{
  "name": "authenticator-next",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "i18n:check": "bun run i18n:extract && bun run i18n:compile && git diff --exit-code -- src/locales",
    "test": "jest",
    "lint": "expo lint",
    "clean-ios": "watchman watch-del-all && rm -fr $TMPDIR/haste-map-* && rm -rf $TMPDIR/metro-cache && bunx expo prebuild --clean && bunx expo run:ios --device --no-build-cache",
    "full-clean-ios": "rm -rf node_modules && bun pm cache rm && bun i && watchman watch-del-all && rm -fr $TMPDIR/haste-map-* && rm -rf $TMPDIR/metro-cache && bunx expo prebuild --clean && bunx expo run:ios --device --no-build-cache"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/material-symbols": "^0.1.1",
    "@expo/ui": "~57.0.2",
    "@formatjs/intl-locale": "^5.3.9",
    "@formatjs/intl-pluralrules": "^6.3.10",
    "@lingui/core": "^6.4.0",
    "@lingui/react": "^6.4.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/app": "^25.1.0",
    "@react-native-firebase/messaging": "^25.1.0",
    "@scure/base": "^2.2.0",
    "expo": "^57.0.0",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.2",
    "expo-camera": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "~57.0.4",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.1",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-notifications": "~57.0.2",
    "expo-router": "~57.0.2",
    "expo-splash-screen": "~57.0.1",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "jest": "~29.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-fast-squircle": "^1.1.5",
    "react-native-pulsar": "^1.6.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@lingui/babel-plugin-lingui-macro": "^6.4.0",
    "@lingui/cli": "^6.4.0",
    "@lingui/metro-transformer": "^6.4.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.17",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lingui": "^0.14.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}
