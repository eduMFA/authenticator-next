{
  "cli": {
    "version": ">= 16.31.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "bun": "1.3.14"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal"
    },
    "beta": {
      "extends": "base",
      "distribution": "store",
      "autoIncrement": true
    },
    "beta-apk": {
      "extends": "beta",
      "autoIncrement": false,
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true
    },
    "production-apk": {
      "extends": "production",
      "autoIncrement": false,
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "beta": {
      "android": {
        "track": "beta"
      },
      "ios": {}
    },
    "production": {
      "android": {
        "track": "production"
      },
      "ios": {}
    }
  }
}
