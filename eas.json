{
  "cli": {
    "version": ">= 16.31.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "bun": "1.3.9"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal"
    },
    "beta": {
      "extends": "base",
      "distribution": "store",
      "autoIncrement": true
    },
    "production": {
      "extends": "base",
      "autoIncrement": true
    }
  },
  "submit": {
    "beta": {
      "android": {
        "track": "beta"
      },
      "ios": {}
    },
    "production": {
      "android": {
        "track": "production"
      },
      "ios": {}
    }
  }
}
